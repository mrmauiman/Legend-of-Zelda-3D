; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

warnings/check_invalid_track_paths=false

[application]

config/name="The Legend of Zelda 3D"
run/main_scene="uid://kt6u3fjqr3cs"
config/features=PackedStringArray("4.5", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/fullsize=false
boot_splash/use_filter=false
boot_splash/image="uid://c22gpwn6j2a0d"
config/icon="uid://b4of84ifeiixl"

[autoload]

Encryption="*res://scripts/components/encryption.gd"
Inventory="*res://scripts/link/inventory.gd"
EnemyDrops="*res://scripts/enemy_drops.gd"
Settings="*res://scripts/ui/settings.gd"
SoundSystem="*res://scenes/sound_system.tscn"
PauseMenu="*res://scenes/ui/pause_menu.tscn"
DoorAnimation="*res://scenes/misc/door_animation.tscn"
EnemyTracker="*res://scripts/chunked_world/enemy_tracker.gd"
Randomizer="*res://scripts/randomizer.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_height"

[editor_plugins]

enabled=PackedStringArray("res://addons/GPUTrail-main/plugin.cfg")

[global_group]

RaftTrigger="Trigger area for raft"
Link=""
Water=""
StepLadderArea=""
Fire=""
Pushable=""
Boomerang=""
Door=""

